# AI Operating System — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Anthropic API ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── GCP ───
GCP_PROJECT_ID=ai-operating-system-490208
GCP_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ─── Cloud SQL (shared with Bharatvarsh) ───
AI_OS_DB_HOST=127.0.0.1
AI_OS_DB_PORT=5432
AI_OS_DB_NAME=ai_os
AI_OS_DB_USER=ai_os_admin
AI_OS_DB_PASSWORD=<from Secret Manager: AI_OS_DB_PASSWORD>
CLOUD_SQL_INSTANCE=bharatvarsh-website:us-central1:bharatvarsh-db

# ─── Bharatvarsh Website (reference) ───
BHARATVARSH_DATABASE_URL=postgresql://...
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
RESEND_API_KEY=

# ─── WhatsApp Business (future) ───
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Google OAuth (for MCP Gateway) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── MCP Gateway Auth ───
MCP_GATEWAY_BEARER_TOKEN=<generate a random token for Claude connections>

# ─── Model Routing ───
DEFAULT_MODEL=claude-sonnet-4-6
COMPLEX_MODEL=claude-opus-4-6
FAST_MODEL=claude-haiku-4-5
