# AI Operating System — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Anthropic API ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── GCP ───
GCP_PROJECT_ID=ai-os-project
GCP_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Bharatvarsh Website (reference) ───
BHARATVARSH_DATABASE_URL=postgresql://...
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
RESEND_API_KEY=

# ─── WhatsApp Business (future) ───
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Model Routing ───
DEFAULT_MODEL=claude-sonnet-4-6
COMPLEX_MODEL=claude-opus-4-6
FAST_MODEL=claude-haiku-4-5
