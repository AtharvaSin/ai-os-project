# AI OS Gateway — Local Development Environment
# -----------------------------------------------
# Copy this file to docker/.env.local and fill in ANTHROPIC_API_KEY.
# Everything else is pre-filled for the local Docker stack.
# .env.local is gitignored — never commit it.

# --- Database (local override) ---
DB_HOST=postgres-local
DB_PORT=5432
DB_NAME=ai_os
DB_USER=ai_os_admin
DB_PASSWORD=localdev

# --- Gateway ---
MCP_GATEWAY_API_KEY=localdev
PORT=8080

# --- AI ---
ANTHROPIC_API_KEY=                # Required — fill in your key
OPENAI_API_KEY=                   # Optional for local dev

# --- Google (optional for local) ---
# Leave blank unless testing Drive/Calendar/Tasks tools locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Telegram (optional for local) ---
# Leave blank unless testing Telegram bot commands locally.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# --- Social (optional for local) ---
# Leave blank unless testing social posting tools locally.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# --- Gemini (optional for local) ---
# Required only for media_gen image generation tools.
GEMINI_API_KEY=
