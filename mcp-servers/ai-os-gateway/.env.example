# Local development — copy to .env and fill in values
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_os
DB_USER=ai_os_admin
DB_PASSWORD=your_password_here

# Cloud Run sets this automatically via --add-cloudsql-instances
DB_SOCKET_PATH=/cloudsql/bharatvarsh-website:us-central1:bharatvarsh-db

# Authentication
MCP_GATEWAY_API_KEY=your_api_key_here

# Google OAuth (Phase 2) — leave blank until Phase 2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Environment detection
ENVIRONMENT=local
