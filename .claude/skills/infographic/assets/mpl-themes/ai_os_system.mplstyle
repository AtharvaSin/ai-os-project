# AI OS System — Matplotlib Brand Theme
# Context A: Wibify-inspired / Obsidian Aurora
# Generated by brand-system-build Phase 3
# Accent Primary: #00D492 (electric emerald from Wibify extraction)

# Figure
figure.facecolor: "#0d0d14"
figure.edgecolor: "#1f1f35"
figure.figsize: 12, 7
figure.dpi: 100
figure.titlesize: 14
figure.titleweight: bold

# Axes
axes.facecolor: "#12121e"
axes.edgecolor: "#1f1f35"
axes.linewidth: 0.8
axes.labelcolor: "#A09D95"
axes.labelsize: 11
axes.labelpad: 8
axes.titlesize: 13
axes.titleweight: bold
axes.titlepad: 14
axes.spines.top: False
axes.spines.right: False
axes.spines.left: True
axes.spines.bottom: True
axes.grid: True
axes.axisbelow: True
axes.prop_cycle: cycler('color', ["#00D492", "#E8B931", "#7B68EE", "#FF6B6B", "#A09D95"])

# Grid
grid.color: "#1a1a2e"
grid.linewidth: 0.6
grid.alpha: 0.8
grid.linestyle: --

# Tick marks
xtick.color: "#A09D95"
xtick.labelsize: 10
xtick.labelcolor: "#A09D95"
xtick.direction: out
xtick.major.size: 4
xtick.minor.visible: False

ytick.color: "#A09D95"
ytick.labelsize: 10
ytick.labelcolor: "#A09D95"
ytick.direction: out
ytick.major.size: 4
ytick.minor.visible: False

# Legend
legend.facecolor: "#1a1a2e"
legend.edgecolor: "#1f1f35"
legend.fontsize: 10
legend.labelcolor: "#EEEAE4"
legend.framealpha: 1.0
legend.borderpad: 0.6
legend.labelspacing: 0.4

# Lines
lines.linewidth: 2.0
lines.markersize: 6

# Bars
patch.linewidth: 0
patch.edgecolor: none

# Text
text.color: "#EEEAE4"
font.family: sans-serif
font.sans-serif: DM Sans, Inter, Helvetica Neue, Arial, sans-serif
font.size: 11

# Savefig
savefig.facecolor: "#0d0d14"
savefig.edgecolor: none
savefig.dpi: 150
savefig.bbox: tight
savefig.pad_inches: 0.15
