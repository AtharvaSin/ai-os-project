{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["es2022", "DOM"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": {
      "@common/*": ["src/common/*"],
      "@projects/*": ["src/projects/*"],
      "@engine/*": ["src/engine/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["remotion.config.ts", "node_modules"]
}
