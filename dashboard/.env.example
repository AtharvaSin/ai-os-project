# Database (Cloud SQL Auth Proxy)
DB_HOST=/cloudsql/bharatvarsh-website:us-central1:bharatvarsh-db
DB_NAME=ai_os
DB_USER=ai_os_admin
DB_PASSWORD=

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloud Run sets PORT=8080 automatically
PORT=3000
